{
  "name": "captionsan",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @captionsan/* dev",
    "build": "pnpm --filter @captionsan/* build",
    "db:generate": "pnpm --filter @captionsan/db generate",
